            "in": "query",
            "name": "timestamps",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Date basis: 'processed_date' (default, TigerBeetle) or 'value_date' (Athena)",
            "in": "query",
            "name": "date_type",
            "schema": {
              "enum": [
                "processed_date",
                "value_date"
              ],
              "type": "string"
            }
          },
          {
            "description": "Filter by template ID; only include transfers from this template (ignored for value_date)",
            "in": "query",
            "name": "template_id",
            "schema": {
              "maximum": 65535,
              "minimum": 1,
              "type": "integer"
            }
          }
