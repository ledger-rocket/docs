        "description": "Aggregate clearing + intention between two FBO rail instances.",
        "trigger": "sweep_engine_identifies_intra_rail_imbalance",
        "repeat_while": "rail_pairs_remaining_in_sweep_batch",
        "repeat_while_description": "Repeats for each rail pair in the sweep batch."
