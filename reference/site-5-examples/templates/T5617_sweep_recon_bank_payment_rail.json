{
  "template": {
    "$schema": "https://ledger-rocket.github.io/schemas/domain/template.schema.json",
    "site_id": 5,
    "template_id": 5617,
    "name": "sweep_recon_bank_payment_rail",
    "description": "Intra-FBO inter-rail sweep reconciliation: flush suspense against control for one rail instance. Operates on both economic ledger (10103/10102) and allocation ledger (11903/11902). Bidirectional: for the source rail, DR suspense CR control. For the dest rail, DR control CR suspense. Caller controls direction by assigning accounts to debit/credit purposes.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification: suspense zeroed against control for one rail. Net zero on economic ledger.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "economic_ledger"
      },
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification: CB suspense zeroed against CB control for one rail. Net zero on allocation ledger.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "allocation_ledger"
      }
    ],
    "category": "RECONCILIATION",
    "product": "SUSPENSE_MANAGEMENT",
    "event_type": "TRANSFER",
    "trigger": "Reconciliation service matches intra-rail bank payment for one rail.",
    "ledger_scope_descriptions": {
      "allocation_ledger": "Allocation ledger (ID 5002) where CB suspense/control are zeroed for one rail.",
      "economic_ledger": "Economic ledger (ID 5001) where suspense/control are zeroed for one rail."
    },
    "accounting_treatments": [
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          }
        ],
        "description": "Match control against suspense to complete intra-rail bank payment reconciliation for one rail."
      }
    ],
    "account_code_validations": [
      {
        "description": "FBO Suspense or Control asset; debited side of economic flush.",
        "mask": "10102|10103",
        "purpose": "debit_economic"
      },
      {
        "description": "FBO Suspense or Control asset; credited side of economic flush.",
        "mask": "10102|10103",
        "purpose": "credit_economic"
      },
      {
        "description": "CB Suspense or Control asset; debited side of allocation flush.",
        "mask": "11902|11903",
        "purpose": "debit_allocation"
      },
      {
        "description": "CB Suspense or Control asset; credited side of allocation flush.",
        "mask": "11902|11903",
        "purpose": "credit_allocation"
      }
    ],
