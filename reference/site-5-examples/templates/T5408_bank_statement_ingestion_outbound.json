{
  "template": {
    "$schema": "https://ledger-rocket.github.io/schemas/domain/template.schema.json",
    "site_id": 5,
    "template_id": 5408,
    "name": "bank_statement_ingestion_outbound",
    "description": "Ingest an outbound bank statement line item (wire transfer, ACH payment, etc.) into the Economic ledger. Debits Control (10102) to stage the outflow for reconciliation; credits Settled (10100) to recognise confirmed cash leaving the bank account.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification between Control and Settled; total house assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "house"
      }
    ],
    "category": "RECONCILIATION",
    "product": "DEPOSITS",
    "event_type": "TRANSFER",
    "trigger": "System processes a single outbound line item from a bank statement file; fires once per outbound line item.",
    "ledger_scope_descriptions": {
      "house": "Reporting entity (house) ledger representing confirmed bank cash (Settled) and reconciliation staging cash (Control); no customer subledger impact."
    },
    "accounting_treatments": [
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "ASC_305",
            "version": 1
          }
        ],
        "description": "Reclassify confirmed outbound cash from Control staging to Settled; no P&L impact and no customer balance impact."
      }
    ],
    "account_code_validations": [
      {
        "description": "House settled bank cash account (confirmed physical cash at Purple Splash FBO bank account).",
        "mask": "10100",
        "purpose": "settled_account"
      },
      {
        "description": "House control (reconciliation staging) bank cash account; per-file instance selected by statement_file_id external_id.",
        "mask": "10102",
        "purpose": "control_account"
      }
    ],
    "metadata_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "transaction_ref": {
          "description": "Bank-provided transaction reference identifier for this statement line item.",
          "type": "string"
        },
        "line_item_description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional human-readable description from the bank statement line."
        },
        "statement_file_id": {
          "description": "External_id of the source bank statement file; used to select the per-file Control account instance.",
          "type": "string"
        }
      },
      "required": [
        "statement_file_id",
        "transaction_ref"
      ],
      "type": "object"
    },
    "validations": [],
    "variables": [],
    "legs": [
      {
        "amount": "event.amount",
        "credit_account": "accounts.settled_account.account_id",
        "credit_account_type": "ASSET",
        "debit_account": "accounts.control_account.account_id",
        "debit_account_type": "ASSET",
        "description": "Ingest outbound bank statement line; control stages the debit for reconciliation while settled reflects the cash decrease.",
        "leg_number": 1,
        "ledger_scope": "house",
        "treatment_type": "internal_transfer"
      }
    ],
