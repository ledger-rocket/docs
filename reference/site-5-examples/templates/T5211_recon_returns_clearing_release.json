    "name": "recon_returns_clearing_release",
    "description": "Flush the return clearing balance through Suspense AND release customer funds from Hold to Available. Leg 1 moves Suspense (10103) to Clearing Total (10101) on the economic ledger (reverse direction from T5210 because returns flow opposite). Leg 2 releases Customer Hold (20101) to Customer Available (20100). Legs 3 and 4 mirror on the allocation ledger. Structurally identical to UC1's T5402 but for disbursement returns.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the economic ledger: Suspense (10103) decreases and Clearing Total (10101) decreases. Total assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "operational"
      },
      {
        "account_type": "LIABILITY",
        "description": "Liability-to-liability reclassification on the economic ledger: Customer Hold (20101) decreases and Customer Available (20100) increases. Total liabilities unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "operational"
      },
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the allocation ledger: Cash Balances - Suspense (11903) decreases and Cash Balances - Clearing (11901) decreases. Total assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      },
      {
        "account_type": "LIABILITY",
        "description": "Liability-to-liability reclassification on the allocation ledger: Customer - Master FBO Clearing (21101) decreases and Customer - Master FBO (21100) increases. Total liabilities unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      }
    ],
    "category": "RECONCILIATION",
    "product": "SUSPENSE_MANAGEMENT",
    "event_type": "TRANSFER",
    "trigger": "Reconciliation service matches a return clearing entry against the bank statement. Fires once per return line reconciled.",
    "capabilities": [
      "allows_intercompany_transfers"
    ],
    "ledger_scope_descriptions": {
      "fdic_tracking": "FDIC tracking ledger (ID 5002) where the clearing flush and customer release are mirrored for FDIC tracking.",
      "operational": "Operational ledger (ID 5001) where return clearing is flushed through Suspense and customer funds are released from Hold to Available."
    },
    "accounting_treatments": [
