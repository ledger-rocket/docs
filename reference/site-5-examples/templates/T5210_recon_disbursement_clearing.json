    "name": "recon_disbursement_clearing",
    "description": "Flush the disbursement clearing balance through Suspense. Moves Clearing Total (10101) to Suspense (10103) on the economic ledger, with a mirror of Cash Balances - Clearing (11901) to Cash Balances - Suspense (11903) on the allocation ledger. This is the disbursement-side equivalent of UC1's clearing flush. Fires per disbursement detail line reconciled.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the economic ledger: Clearing Total (10101) decreases and Suspense (10103) increases. Total assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "operational"
      },
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the allocation ledger: Cash Balances - Clearing (11901) decreases and Cash Balances - Suspense (11903) increases. Total assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      }
    ],
    "category": "RECONCILIATION",
    "product": "SUSPENSE_MANAGEMENT",
    "event_type": "TRANSFER",
    "trigger": "Reconciliation service matches a disbursement clearing entry against the bank statement. Fires once per disbursement detail line reconciled.",
    "ledger_scope_descriptions": {
      "fdic_tracking": "FDIC tracking ledger (ID 5002) where Cash Balances - Clearing is flushed to Cash Balances - Suspense for FDIC tracking.",
      "operational": "Operational ledger (ID 5001) where Clearing Total is flushed to Suspense for reconciliation."
    },
    "accounting_treatments": [
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          },
          {
