    "name": "Ingest detail data for allocation file",
    "description": "When an allocation file is received, deposit is allocated across customers and to the file specific account for consistency checks",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Master FBO - Clearing (10101) per-file instance is debited on the economic ledger, drawing down the clearing balance established by the batch header (T5102).",
        "impact": "increase",
        "ledger_scope": "economic_ledger"
      },
      {
        "account_type": "LIABILITY",
        "description": "Customer Hold (20101) is credited, increasing the consumer deposit hold liability.",
        "impact": "increase",
        "ledger_scope": "economic_ledger"
      },
      {
        "account_type": "ASSET",
        "description": "Cash Balances - Clearing (11901) is debited on the allocation ledger, recording the expected FDIC fund location.",
        "impact": "increase",
        "ledger_scope": "allocation_ledger"
      },
      {
        "account_type": "LIABILITY",
        "description": "Consumer Master FBO Clearing (21101) is credited, increasing the expected consumer FDIC position.",
        "impact": "increase",
        "ledger_scope": "allocation_ledger"
      }
    ],
    "category": "DEPOSITS",
    "product": "DEPOSITS",
    "event_type": "DEPOSIT",
    "trigger": "Per-consumer line item in a bulk deposit allocation file, after the batch header (T5102) has established the per-file clearing balance.",
    "capabilities": [
      "allows_intercompany_transfers"
    ],
    "ledger_scope_descriptions": {
      "economic_ledger": "Economic ledger (ID 5001) where the per-file clearing balance is drawn down and consumer available balances are credited.",
      "allocation_ledger": "Allocation ledger (ID 5002) where Cash Balances and consumer FBO Main positions are updated for FDIC tracking."
    },
    "accounting_treatments": [
      {
        "type": "customer_deposit_receipt",
        "policy_refs": [
          {
            "id": "ASC_942",
            "version": 1
          }
        ],
        "description": "Allocate a customer deposit by drawing down the per-file clearing balance and increasing the specific consumer deposit liability; executed per consumer line item."
      },
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          }
        ],
        "description": "Record the FDIC fund location movement by debiting Cash Balances and crediting the consumer's FBO Main account on the allocation ledger."
      }
    ],
    "account_code_validations": [
      {
        "description": "Per-file clearing instance (Master FBO - Clearing) on the economic ledger; debited to draw down the clearing balance for this consumer's allocation.",
        "mask": "10101",
        "purpose": "clearing_per_file"
      },
      {
        "description": "Consumer on-balance-sheet deposit liability (funds on hold pending reconciliation) credited for the allocation amount.",
        "mask": "20101",
        "purpose": "consumer_hold"
      },
      {
        "description": "Cash Balances - Clearing asset on the allocation ledger; debited to record the expected FDIC fund location for this consumer's deposit.",
        "mask": "11901",
        "purpose": "cash_balances_clearing"
      },
      {
        "description": "Consumer Master FBO Clearing liability on the allocation ledger; credited for FDIC fund location tracking of expected movements.",
        "mask": "21101",
        "purpose": "consumer_fbo_clearing"
      }
    ],
