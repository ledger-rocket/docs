{
  "template": {
    "$schema": "",
    "site_id": 5,
    "template_id": 5602,
    "name": "sweep_customer_allocation",
    "description": "UC6 Step 2: Creates expected movements of cash between Master FBO and Program Bank X at customer level. Leg 1 on the allocation ledger creates per-customer clearing positions between Cash Balances Clearing accounts (11901). Leg 2 on the intention ledger queues per-customer sweep intentions between source and destination intention accounts (8100/8200). Direction is bidirectional -- the caller swaps which accounts are debited vs credited depending on whether the customer's funds are moving to or from the program bank.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification between two Cash Balances Clearing accounts. Net zero.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      },
      {
        "account_type": "SUPPLEMENTAL",
        "description": "Supplemental-to-supplemental reclassification: destination intention debited, source intention credited. Net zero.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "sweep_queue"
      }
    ],
    "category": "SWEEP",
    "product": "FDIC_SWEEP",
    "event_type": "TRANSFER",
    "trigger": "Sweep job identifies required per-customer movement between Master FBO and Program Bank X.",
    "ledger_scope_descriptions": {
      "fdic_tracking": "FDIC tracking ledger (ID 5002) where per-customer clearing positions are created between banks.",
      "sweep_queue": "Sweep queue ledger (ID 5003) where per-customer sweep intentions are queued."
    },
    "accounting_treatments": [
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          }
        ],
        "description": "Create expected clearing positions for inter-bank sweep at customer allocation level."
      },
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          }
        ],
        "description": "Queue per-customer sweep intention between source and destination bank."
      }
    ],
    "account_code_validations": [
      {
        "description": "Cash Balances Clearing asset; debited to create expected inbound movement.",
        "mask": "11901",
        "purpose": "debit_clearing"
      },
      {
        "description": "Cash Balances Clearing asset; credited to create expected outbound movement.",
        "mask": "11901",
        "purpose": "credit_clearing"
      },
      {
        "description": "Sweep source intention supplemental; credited to queue per-customer sweep source.",
        "mask": "8100|8200",
        "purpose": "source_intention"
      },
      {
        "description": "Sweep destination intention supplemental; debited to queue per-customer sweep destination.",
        "mask": "8100|8200",
        "purpose": "destination_intention"
      }
    ],
    "metadata_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "fbo_balance": {
          "description": "Master FBO balance formatted as dollars with cents (e.g. \"755509.34\").",
          "type": "string",
          "example": "755509.34"
        },
        "network_position": {
          "description": "Net network position formatted as dollars with cents (e.g. \"0.00\").",
          "type": "string",
          "example": "0.00"
        },
        "consumer_external_id": {
          "type": "string",
          "description": "Consumer entity external identifier.",
          "maxLength": 100,
          "minLength": 1
        },
        "sweep_batch_id": {
          "maxLength": 100,
          "minLength": 1,
          "type": "string",
          "description": "Unique identifier for the sweep batch."
        },
        "direction": {
          "type": "string",
          "enum": [
            "out",
            "in"
          ],
          "description": "Direction of the sweep movement."
        }
      },
      "required": [
        "sweep_batch_id",
        "consumer_external_id",
        "direction",
        "fbo_balance",
        "network_position"
      ],
      "type": "object"
    },
    "validations": [
      {
        "description": "Sweep source and destination intention accounts must use different account codes.",
        "expression": "accounts.source_intention.account_code.code != accounts.destination_intention.account_code.code",
        "name": "distinct_intention_codes"
      }
    ],
    "variables": [],
    "legs": [
      {
        "amount": "event.amount",
        "credit_account": "accounts.credit_clearing.account_id",
        "credit_account_type": "ASSET",
        "debit_account": "accounts.debit_clearing.account_id",
        "debit_account_type": "ASSET",
        "description": "Track per-customer FDIC fund reallocation between banks for the sweep.",
        "leg_number": 1,
        "ledger_scope": "fdic_tracking",
        "treatment_type": "settlement_clearing"
      },
      {
        "amount": "event.amount",
        "credit_account": "accounts.source_intention.account_id",
        "credit_account_type": "SUPPLEMENTAL",
        "debit_account": "accounts.destination_intention.account_id",
        "debit_account_type": "SUPPLEMENTAL",
        "description": "Queue per-customer sweep intention: destination debited (inbound expected), source credited (outbound queued).",
        "leg_number": 2,
        "ledger_scope": "sweep_queue",
        "treatment_type": "internal_transfer"
      }
    ],
