    "name": "sweep_recon_clearing_rail",
    "description": "Intra-FBO inter-rail sweep reconciliation: flush clearing to suspense for one rail instance on the economic ledger. Bidirectional: for the source rail (clearing has debit balance), DR clearing CR suspense. For the dest rail (clearing has credit balance), DR suspense CR clearing. Caller controls direction by assigning accounts to debit/credit purposes.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification: clearing flushed to suspense for one rail instance. Net zero on economic ledger.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "economic_ledger"
      }
    ],
    "category": "RECONCILIATION",
    "product": "SUSPENSE_MANAGEMENT",
    "event_type": "TRANSFER",
    "trigger": "Reconciliation service matches intra-rail clearing against bank statement for one rail.",
    "ledger_scope_descriptions": {
      "economic_ledger": "Economic ledger (ID 5001) where clearing is flushed to suspense for one rail."
    },
    "accounting_treatments": [
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "ASC_205",
            "version": 1
          }
        ],
        "description": "Flush clearing balance to suspense for one rail instance in intra-rail reconciliation."
      }
    ],
    "account_code_validations": [
      {
        "description": "FBO Clearing or Suspense asset; debited side of flush.",
        "mask": "10101|10103",
        "purpose": "debit_clearing_suspense"
      },
      {
        "description": "FBO Clearing or Suspense asset; credited side of flush.",
        "mask": "10101|10103",
        "purpose": "credit_clearing_suspense"
      }
    ],
    "metadata_schema": {
