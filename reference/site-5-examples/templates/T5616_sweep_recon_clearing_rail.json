      "type": "object"
    },
    "validations": [
      {
        "description": "Debit and credit accounts must use different account codes (one clearing, one suspense).",
        "expression": "accounts.debit_clearing_suspense.account_code.code != accounts.credit_clearing_suspense.account_code.code",
        "name": "distinct_codes"
