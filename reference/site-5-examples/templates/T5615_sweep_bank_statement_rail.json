        "debit_account_type": "ASSET",
        "description": "Mirror on allocation ledger: CB control vs CB settled for one rail.",
        "leg_number": 2,
        "ledger_scope": "allocation_ledger",
        "treatment_type": "cash_movement"
      }
    ],
