{
  "template": {
    "$schema": "https://ledger-rocket.github.io/schemas/domain/template.schema.json",
    "site_id": 5,
    "template_id": 5615,
    "name": "sweep_bank_statement_rail",
    "description": "Intra-FBO inter-rail sweep: bank statement confirming cash movement on one rail within the Master FBO. Fired once per rail per sweep \u2014 source rail fires with DR control CR settled (cash leaving), dest rail fires with DR settled CR control (cash arriving). Bidirectional: caller controls direction by assigning accounts to debit/credit purposes. Leg 1 on economic ledger (10100/10102), Leg 2 mirrors on allocation ledger (11900/11902).",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on economic ledger: control staged against settled for one rail. Net zero.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "economic_ledger"
      },
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on allocation ledger: CB control staged against CB settled for one rail. Net zero.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "allocation_ledger"
      }
    ],
    "category": "SWEEP",
    "product": "FDIC_SWEEP",
    "event_type": "TRANSFER",
    "trigger": "Bank statement received confirming one side of an intra-FBO inter-rail transfer.",
    "ledger_scope_descriptions": {
      "allocation_ledger": "Allocation ledger (ID 5002) where FDIC cash balance position is updated for one FBO rail instance.",
      "economic_ledger": "Economic ledger (ID 5001) where cash position is updated for one FBO rail instance."
    },
    "accounting_treatments": [
      {
        "type": "cash_movement",
        "policy_refs": [
          {
            "id": "ASC_230",
            "version": 1
          }
        ],
        "description": "Record bank statement entry for one side of an intra-rail cash movement."
      }
    ],
    "account_code_validations": [
      {
        "description": "FBO Settled or Control asset; debited side of economic reclassification.",
        "mask": "10100|10102",
        "purpose": "debit_economic"
      },
      {
        "description": "FBO Settled or Control asset; credited side of economic reclassification.",
        "mask": "10100|10102",
        "purpose": "credit_economic"
      },
      {
        "description": "CB Settled or Control asset; debited side of allocation reclassification.",
        "mask": "11900|11902",
        "purpose": "debit_allocation"
      },
      {
        "description": "CB Settled or Control asset; credited side of allocation reclassification.",
        "mask": "11900|11902",
        "purpose": "credit_allocation"
      }
    ],
    "metadata_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "statement_id": {
          "type": "string",
          "description": "Bank statement identifier.",
          "maxLength": 100,
          "minLength": 1
        },
        "statement_line_ref": {
          "minLength": 1,
          "type": "string",
          "description": "Statement line reference.",
          "maxLength": 100
        }
      },
      "required": [
        "statement_id",
        "statement_line_ref"
      ],
      "type": "object"
    },
    "validations": [
      {
        "description": "Economic debit and credit accounts must use different account codes (one settled, one control).",
        "expression": "accounts.debit_economic.account_code.code != accounts.credit_economic.account_code.code",
        "name": "distinct_economic_codes"
      },
      {
        "description": "Allocation debit and credit accounts must use different account codes (one settled, one control).",
        "expression": "accounts.debit_allocation.account_code.code != accounts.credit_allocation.account_code.code",
        "name": "distinct_allocation_codes"
      }
    ],
    "variables": [],
    "legs": [
