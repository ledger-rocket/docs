{
  "template": {
    "$schema": "https://ledger-rocket.github.io/schemas/domain/template.schema.json",
    "site_id": 5,
    "template_id": 5402,
    "name": "reconciliation_flush_clearing",
    "description": "Complete the reconciliation cycle by (1) flushing Suspense against Clearing Total on the economic ledger, (2) releasing consumer funds from Hold to Available on the economic ledger, (3) mirroring the clearing flush on the allocation ledger (CB Suspense to CB Clearing), and (4) mirroring the consumer release on the allocation ledger (FBO Clearing to FBO Main). Fires once per consumer after the reconciliation service confirms the bank statement and allocation file agree.",
    "financial_statements_impact": [
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the economic ledger: Suspense (10103) decreases and Clearing Total (10101) decreases by the same amount. Total economic ledger assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "operational"
      },
      {
        "account_type": "LIABILITY",
        "description": "Liability-to-liability reclassification on the economic ledger: Consumer Hold (20101) decreases and Consumer Available (20100) increases by the same amount. Total economic ledger liabilities unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "operational"
      },
      {
        "account_type": "ASSET",
        "description": "Asset-to-asset reclassification on the allocation ledger: Cash Balances Suspense (11903) decreases and Cash Balances Clearing (11901) decreases by the same amount. Total allocation ledger assets unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      },
      {
        "account_type": "LIABILITY",
        "description": "Liability-to-liability reclassification on the allocation ledger: Consumer FBO Clearing (21101) decreases and Consumer FBO Main (21100) increases by the same amount. Total allocation ledger liabilities unchanged.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "fdic_tracking"
      }
    ],
    "category": "RECONCILIATION",
    "product": "SUSPENSE_MANAGEMENT",
    "event_type": "TRANSFER",
    "trigger": "Reconciliation service triggers consumer release after confirming: Allocation Clearing per-file = 0, Unallocated Customer per-file = 0, and bank statement Control flush (T5407) has fired. Fires once per consumer.",
    "capabilities": [
      "allows_intercompany_transfers"
    ],
    "ledger_scope_descriptions": {
      "operational": "Operational ledger (ID 5001) where Clearing Total and Suspense are maintained for reconciliation, and Consumer Hold and Available track deposit liabilities.",
      "fdic_tracking": "FDIC tracking ledger (ID 5002) where Cash Balances Clearing and Suspense mirror the economic reconciliation, and Consumer FBO Clearing and Main track FDIC custodial positions."
    },
    "accounting_treatments": [
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "IAS_1",
            "version": 1
          },
          {
            "id": "IFRS_9",
            "version": 1
          }
        ],
        "description": "Flush the accumulated allocation clearing balance into Suspense for reconciliation against the corresponding bank statement Control flush."
      },
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "IAS_1",
            "version": 1
          }
        ],
        "description": "Release consumer funds from Hold to Available on the economic ledger after bank confirmation."
      },
      {
        "type": "settlement_clearing",
        "policy_refs": [
          {
            "id": "IAS_1",
            "version": 1
          },
          {
            "id": "IFRS_9",
            "version": 1
          }
        ],
        "description": "Mirror the clearing flush on the allocation ledger for FDIC position tracking."
      },
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "IAS_1",
            "version": 1
          }
        ],
        "description": "Release consumer FDIC custodial position from FBO Clearing to FBO Main on the allocation ledger."
      }
    ],
    "account_code_validations": [
      {
        "description": "Reconciliation suspense / mixing bowl (Master FBO - Suspense); debited to receive the clearing balance.",
        "mask": "10103",
        "purpose": "suspense_account"
      },
      {
        "description": "Permanent clearing accumulator (Master FBO - Clearing Total); credited to flush the accumulated batch header balance.",
        "mask": "10101",
        "purpose": "clearing_total"
      },
      {
        "description": "Consumer deposit hold liability on the economic ledger; debited to release funds to the consumer's available balance.",
        "mask": "20101",
        "purpose": "consumer_hold"
      },
      {
        "description": "Consumer available deposit liability on the economic ledger; credited to make funds available to the consumer.",
        "mask": "20100",
        "purpose": "consumer_available"
      },
      {
        "description": "Cash Balances Suspense on the allocation ledger; debited to mirror the economic clearing flush.",
        "mask": "11903",
        "purpose": "cash_balances_suspense"
      },
      {
        "description": "Cash Balances Clearing on the allocation ledger; credited to mirror the economic clearing flush for FDIC tracking.",
        "mask": "11901",
        "purpose": "cash_balances_clearing"
      },
      {
        "description": "Consumer FBO Clearing liability on the allocation ledger; debited to release the FDIC custodial position.",
        "mask": "21101",
        "purpose": "consumer_fbo_clearing"
      },
      {
        "description": "Consumer FBO Main liability on the allocation ledger; credited to establish the consumer's final FDIC custodial position.",
        "mask": "21100",
        "purpose": "consumer_fbo_main"
      }
    ],
