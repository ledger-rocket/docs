{
  "template": {
    "$schema": "https://ledger-rocket.github.io/schemas/domain/template.schema.json",
    "site_id": 5,
    "template_id": 5201,
    "name": "disbursement_hold_authorization",
    "description": "Authorization step for a consumer payout request: reserve funds by moving value from Customer-Available (20100) to Customer-Hold (20101) on the Economic Ledger, reducing spendable balance and preventing overdrafts prior to payment-rail interaction.",
    "financial_statements_impact": [
      {
        "account_type": "LIABILITY",
        "description": "Liability reclassification within customer balances (Customer-Available to Customer-Hold) with no net change to total liabilities.",
        "impact": "increase_or_no_impact",
        "ledger_scope": "primary"
      }
    ],
    "category": "PAYMENTS",
    "product": "PAYMENTS",
    "event_type": "TRANSFER",
    "trigger": "Consumer requests a payout; system places a disbursement hold before initiating ACH/wire/PayPal/push-to-debit.",
    "ledger_scope_descriptions": {
      "primary": "Economic (main) ledger scope where customer liability sub-accounts (e.g., available and hold) are recorded."
    },
    "accounting_treatments": [
      {
        "type": "internal_transfer",
        "policy_refs": [
          {
            "id": "ASC_405-20",
            "version": 1
          }
        ],
        "description": "Reclassify consumer funds within customer liabilities from available balance to held/authorized balance; no settlement occurs and total customer liability remains unchanged."
      }
    ],
    "account_code_validations": [
      {
        "description": "Customer on-balance-sheet deposit liability representing real-time spendable funds per consumer (Customer - Available).",
        "mask": "20100",
        "purpose": "consumer_available"
      },
      {
        "description": "Customer on-balance-sheet deposit liability representing funds reserved/held for pending disbursements per consumer (Customer - Hold).",
        "mask": "20101",
        "purpose": "consumer_hold"
      }
    ],
    "metadata_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "disbursement_method": {
          "description": "Requested disbursement rail/method for the authorized payout.",
          "type": "string",
          "enum": [
            "ACH",
            "push-to-debit",
            "PayPal",
            "wire"
          ]
        },
        "transaction_ref": {
          "type": "string",
          "description": "External transaction reference / idempotency key for the payout authorization (e.g. 'payout_auth_01J0...')."
        },
        "payout_request_id": {
          "description": "Identifier of the payout request being authorized/held (e.g. 'pr_12345').",
          "type": "string"
        }
      },
      "required": [
        "transaction_ref",
        "payout_request_id",
        "disbursement_method"
      ],
      "type": "object"
    },
    "validations": [],
    "variables": [],
    "legs": [
      {
        "amount": "event.amount",
        "credit_account": "accounts.consumer_hold.account_id",
        "credit_account_type": "LIABILITY",
        "debit_account": "accounts.consumer_available.account_id",
        "debit_account_type": "LIABILITY",
        "description": "Place a hold on the consumer's spendable balance to reserve funds for the pending disbursement.",
        "leg_number": 1,
        "ledger_scope": "primary",
        "treatment_type": "internal_transfer"
      }
    ],
